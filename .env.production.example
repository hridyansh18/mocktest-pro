# Render API
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
PGSSL_MODE=require
JWT_ACCESS_SECRET=replace-with-64-plus-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-64-plus-random-secret
JWT_ATTEMPT_SECRET=replace-with-another-64-plus-random-secret
ALLOWED_ORIGINS=https://your-project.vercel.app
SOCKET_CORS_ORIGIN=https://your-project.vercel.app

# Vercel frontend (set in Vercel project settings, not in Render)
VITE_API_URL=https://your-render-service.onrender.com/api
