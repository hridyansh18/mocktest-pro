# Server
PORT=5000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
DATABASE_URL=postgresql://mocktest_user:CHANGE_ME@localhost:5432/mocktest_pro
# disable = local/no TLS, require = encrypted but provider CA not verified,
# verify-full = verify the server certificate (preferred when provider CA is available)
PGSSL_MODE=disable
DB_POOL_MAX=10

# JWT - use three different strong random values
JWT_ACCESS_SECRET=CHANGE_ME_ACCESS_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET
JWT_ATTEMPT_SECRET=CHANGE_ME_ATTEMPT_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Optional separate Socket.IO origins; defaults to ALLOWED_ORIGINS
SOCKET_CORS_ORIGIN=http://localhost:5173
TEST_CODE_PREFIX_DEFAULT=TST
LOG_LEVEL=info

# One-time Super Admin bootstrap. Remove these from Render after npm run bootstrap:admin.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=CHANGE_ME_MINIMUM_12_CHARS
ADMIN_BOOTSTRAP_NAME=MockTest Pro Admin
